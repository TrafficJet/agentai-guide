---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  noindex?: boolean;
  ogImage?: string;
}
const { title, description, canonicalUrl, noindex, ogImage } = Astro.props;
const canon = canonicalUrl || Astro.url.href;
const finalOgImage = ogImage || 'https://agentai-guide.com/og-default.png';
const GA_ID = 'G-41YPQ25ZH6';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#15803d" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canon} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta property="og:image" content={finalOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content={finalOgImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <script type="application/ld+json" is:inline>
  {"@context": "https://schema.org", "@type": "WebSite", "name": "AgentAI Guide — AI for Real Estate Agents", "url": "https://agentai-guide.com/", "description": "Guides and resources for real estate agents using AI tools. Prompts, workflows, and strategies for modern real estate professionals.", "potentialAction": {"@type": "SearchAction", "target": "https://agentai-guide.com/?s={search_term_string}", "query-input": "required name=search_term_string"}}
  </script>
</head>
<body class="bg-white text-gray-900 font-sans">
  <header class="border-b border-gray-200 px-6 py-4">
    <nav class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-green-700">AgentAI Guide</a>
      <ul class="flex gap-6 text-sm text-gray-600">
        <li><a href="/" class="hover:text-green-700">Home</a></li>
        <li><a href="/blog/" class="hover:text-green-700">Blog</a></li>
        <li><a href="/tools/" class="hover:text-green-700">AI Tools</a></li>
        <li><a href="/about/" class="hover:text-green-700">About</a></li>
      </ul>
    </nav>
  </header>
  <main class="max-w-5xl mx-auto px-6 py-10">
    <slot />
  </main>
  <footer class="border-t border-gray-200 px-6 py-8 mt-16 text-sm text-gray-500">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-between gap-4">
      <span>&copy; {new Date().getFullYear()} AgentAI Guide. Independent resource &mdash; not affiliated with any AI company.</span>
      <ul class="flex flex-wrap gap-4">
        <li><a href="/about/" class="hover:text-green-700">About</a></li>
        <li><a href="/privacy/" class="hover:text-green-700">Privacy</a></li>
        <li><a href="/terms/" class="hover:text-green-700">Terms</a></li>
        <li><a href="/contact/" class="hover:text-green-700">Contact</a></li>
        <li class="text-gray-300">|</li>
        <li><a href="https://commission-calc.com/" class="hover:text-green-700">Commission Calc</a></li>
        <li><a href="https://shopify-fee-calc.com/" class="hover:text-green-700">Shopify Fee Calc</a></li>
        <li><a href="https://app-compare.com/" class="hover:text-green-700">App Compare</a></li>
      </ul>
    </div>
  </footer>
  <script defer src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  </script>
</body>
</html>
