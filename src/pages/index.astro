---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 6);
---
<Base title="AgentAI Guide — AI Tools for Real Estate Agents" description="Discover the best AI tools for real estate agents. Listing generators, lead scoring, market analysis, and ChatGPT guides for Realtors.">
  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">AI Tools for Real Estate Agents</h1>
    <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-8">Discover how to use ChatGPT, AI listing generators, and smart automation to close more deals and save hours every week.</p>
    <a href="/blog/" class="inline-block bg-green-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-green-700 transition">Explore Guides →</a>
  </section>

  <!-- Categories -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
    <div class="border border-gray-100 rounded-xl p-6">
      <div class="text-3xl mb-3">✍️</div>
      <h2 class="font-semibold text-lg mb-2">AI Listing Descriptions</h2>
      <p class="text-gray-500 text-sm">Generate compelling MLS descriptions in seconds with AI tools.</p>
      <a href="/blog/" class="text-green-600 text-sm mt-3 inline-block hover:underline">Read guides →</a>
    </div>
    <div class="border border-gray-100 rounded-xl p-6">
      <div class="text-3xl mb-3">🤖</div>
      <h2 class="font-semibold text-lg mb-2">ChatGPT for Agents</h2>
      <p class="text-gray-500 text-sm">Prompts, workflows, and strategies to use ChatGPT in your daily work.</p>
      <a href="/blog/" class="text-green-600 text-sm mt-3 inline-block hover:underline">Read guides →</a>
    </div>
    <div class="border border-gray-100 rounded-xl p-6">
      <div class="text-3xl mb-3">📊</div>
      <h2 class="font-semibold text-lg mb-2">AI Market Analysis</h2>
      <p class="text-gray-500 text-sm">Use AI to analyze market trends, price properties, and generate CMA reports.</p>
      <a href="/blog/" class="text-green-600 text-sm mt-3 inline-block hover:underline">Read guides →</a>
    </div>
  </section>

  <!-- Latest posts -->
  {posts.length > 0 && (
    <section>
      <h2 class="text-2xl font-bold mb-6">Latest Articles</h2>
      <div class="space-y-6">
        {posts.map(post => (
          <article class="border-b border-gray-100 pb-6">
            <a href={`/blog/${post.slug}/`} class="block group">
              <h3 class="text-lg font-semibold group-hover:text-green-700">{post.data.title}</h3>
            </a>
            <p class="text-gray-500 text-sm mt-1">{post.data.description}</p>
            <a href={`/blog/${post.slug}/`} class="text-green-600 text-sm mt-2 inline-block hover:underline">Read more →</a>
          </article>
        ))}
      </div>
    </section>
  )}
</Base>
