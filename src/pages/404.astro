---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | AgentAI Guide" description="That page doesn't exist. Browse our AI agent guides and tool comparisons.">
  <div class="max-w-2xl mx-auto text-center py-20 px-4">
    <p class="text-8xl font-bold text-green-100 mb-2">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">Page not found</h1>
    <p class="text-gray-500 mb-10">That URL doesn't exist. Here are our most popular guides:</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left mb-10">
      <a href="/blog/claude-vs-gpt4-2026/" class="block border border-green-100 rounded-xl p-4 hover:border-green-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Claude vs GPT-4 (2026)</div>
        <div class="text-green-600 text-xs mt-0.5">Honest business comparison →</div>
      </a>
      <a href="/blog/best-ai-coding-assistants-2026/" class="block border border-green-100 rounded-xl p-4 hover:border-green-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Best AI Coding Assistants 2026</div>
        <div class="text-green-600 text-xs mt-0.5">Claude Code, Cursor, Copilot →</div>
      </a>
      <a href="/blog/ai-agents-for-shopify-store-owners/" class="block border border-green-100 rounded-xl p-4 hover:border-green-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">AI Agents for Shopify</div>
        <div class="text-green-600 text-xs mt-0.5">10 tools for store owners →</div>
      </a>
      <a href="/blog/ai-tools-for-real-estate-agents/" class="block border border-green-100 rounded-xl p-4 hover:border-green-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">AI Tools for Real Estate Agents</div>
        <div class="text-green-600 text-xs mt-0.5">Best tools for agents in 2026 →</div>
      </a>
    </div>

    <div class="flex flex-wrap gap-3 justify-center text-sm">
      <a href="/" class="bg-green-700 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-green-800 transition">Home</a>
      <a href="/blog/" class="text-green-600 border border-green-200 px-6 py-2.5 rounded-lg hover:bg-green-50 transition">All Articles</a>
    </div>
  </div>
</Base>
